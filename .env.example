# NexusAI Agency — Environment Variables
# Copy this file to .env and fill in your values

# n8n Webhooks
VITE_SEO_WEBHOOK_URL=https://your-n8n-instance.com/webhook/seo-analysis
VITE_STRATEGY_WEBHOOK_URL=https://your-n8n-instance.com/webhook/strategy-call

# GoHighLevel
VITE_GHL_WEBHOOK_URL=https://your-ghl-instance.com/webhook/contact
VITE_GHL_API_KEY=your_ghl_api_key_here

# HubSpot
VITE_HUBSPOT_PORTAL_ID=your_portal_id_here

# Zapier
VITE_ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxxx/

# Site URL (for SEO)
VITE_SITE_URL=https://yourdomain.com
