          "name": "n8n free OpenAI API credits"
        }
      }
    },
    {
      "parameters": {
        "jsonSchemaExample": "{\n  \"business_name\": \"string\",\n  \"google_maps_url\": \"string\",\n  \"top_competitors\": [\n    {\n      \"name\": \"string\",\n      \"rating\": 0,\n      \"reviews\": 0,\n      \"relevance_score\": 0,\n      \"google_maps_url\": \"string\",\n      \"proximity_estimate\": \"string\",\n      \"primary_keywords_likely_targeted\": [\"string\"]\n    }\n  ],\n  \"seo_insights\": {\n    \"competitor_keywords\": [\"string\"],\n    \"local_keywords\": [\"string\"],\n    \"industry_keywords\": [\"string\"],\n    \"near_me_variations\": [\"string\"]\n  },\n  \"keyword_clusters\": {\n    \"high_intent\": [\"string\"],\n    \"local\": [\"string\"],\n    \"long_tail\": [\"string\"]\n  },\n  \"seo_score_estimate\": {\n    \"score\": 0,\n    \"explanation\": \"string\",\n    \"strengths\": [\"string\"],\n    \"weaknesses\": [\"string\"]\n  },\n  \"recommendations\": [\"string\"]\n}"
      },
      "id": "acefbd42-5aba-41f4-b72c-31dd55f2515e",
      "name": "SEO Analysis Schema",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.3,
      "position": [640, 560]
    },
    {
      "parameters": {
        "jsCode": "const analysis = $input.first().json.output;\n\nconst calculateDifficulty = (keywords) => {\n  if (!Array.isArray(keywords)) return [];\n  return keywords.map(kw => {\n    const text = typeof kw === 'string' ? kw : (kw.keyword || '');\n    const wordCount = text.split(' ').length;\n    const hasLocation = /near me|local|downtown|area/i.test(text);\n\n    let difficulty = 50;\n    if (wordCount > 3) difficulty -= 10;\n    if (hasLocation) difficulty -= 15;\n    if (/best|top|leading/i.test(text)) difficulty += 20;\n\n    difficulty = Math.max(0, Math.min(100, difficulty));\n\n    return {\n      keyword: text,\n      difficulty,\n      opportunity: 100 - difficulty\n    };\n  });\n};\n\nconst overallScore = analysis.seo_score_estimate?.score ?? 50;\n\nconst competitors = analysis.top_competitors || [];\nconst competitorStrength = competitors.length\n  ? Math.round(\n      competitors.reduce((sum, c) => sum + (c.relevance_score || 0), 0)\n      / competitors.length * 10\n    )\n  : 0;\n\nreturn [{\n  json: {\n    overall_seo_score: overallScore,\n    top_competitors: competitors,\n    seo_insights: analysis.seo_insights || {},\n    keyword_analysis: {\n      high_intent: calculateDifficulty(analysis.keyword_clusters?.high_intent),\n      local:       calculateDifficulty(analysis.keyword_clusters?.local),\n      long_tail:   calculateDifficulty(analysis.keyword_clusters?.long_tail)\n    },\n    recommendations: analysis.recommendations || [],\n    seo_score_details: analysis.seo_score_estimate || null,\n    score_breakdown: {\n      competitor_strength: competitorStrength,\n      keyword_opportunity: Math.max(0, 100 - competitorStrength),\n      local_presence:      Math.max(0, overallScore - 10)\n    }\n  }\n}];"
      },
