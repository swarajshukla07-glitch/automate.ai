      "id": "242635f0-6a41-48c8-9136-c38fa4983ba7",
      "name": "Find Nearby Competitors",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [48, 336],
      "credentials": {
        "httpHeaderAuth": {
          "id": "foursquare_header_auth",
          "name": "Foursquare API"
        }
      }
