      "id": "21c14e5f-6682-4841-8ea4-52fa0b4a00a7",
      "name": "OpenAI GPT-5 Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1.3,
      "position": [512, 560],
      "credentials": {
        "openAiApi": {
